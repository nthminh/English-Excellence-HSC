{
  "name": "functions",
  "description": "Firebase Cloud Functions for English Excellence",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.1.0",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "typescript": "~5.8.2"
  },
  "private": true
}
