rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Inquiry submissions: anyone can create, only authenticated admin can read/update/delete
    match /inquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Review submissions: anyone can create and read, no client-side updates or deletes.
    // Status updates (approve / reject) are performed server-side by the
    // `reviewAction` Cloud Function using the Admin SDK, which bypasses these rules.
    match /reviews/{docId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }

    // Resource email signups: anyone can create, only authenticated admin can read/update/delete
    match /resource_signups/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
