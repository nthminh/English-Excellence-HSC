# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Email (Firebase Cloud Functions — set via `firebase functions:config:set`)
# See FIREBASE_SETUP.md for full instructions.
#
# EMAIL_HOST       SMTP server hostname   (e.g. smtp.gmail.com)
# EMAIL_PORT       SMTP port              (587 for TLS, 465 for SSL)
# EMAIL_USER       SMTP login / Gmail address
# EMAIL_PASS       SMTP password / Gmail App Password
# EMAIL_FROM       "From" address shown to recipients
